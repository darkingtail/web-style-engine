{
  "name": "web-style-engine",
  "version": "0.0.0",
  "description": "A framework-agnostic style engine for Web UI.",
  "type": "module",
  "private": false,
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./renderers": {
      "types": "./dist/renderers/index.d.ts",
      "import": "./dist/renderers/index.js"
    },
    "./create-styles": {
      "types": "./dist/create-styles/index.d.ts",
      "import": "./dist/create-styles/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "import": "./dist/tokens/index.js"
    },
    "./migration": {
      "types": "./dist/migration/index.d.ts",
      "import": "./dist/migration/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "docs:dev": "npm --prefix docs-site run dev",
    "docs:build": "npm --prefix docs-site run build"
  },
  "peerDependencies": {
    "@emotion/css": "^11.0.0"
  },
  "peerDependenciesMeta": {
    "@emotion/css": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
